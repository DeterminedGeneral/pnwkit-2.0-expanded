{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./src",                    // Make sure this points to your source files
    "outDir": "./build",                   // Compiled .js files go here
    "declaration": true,                   // Generate .d.ts files
    "declarationDir": "./build/types",     // Output .d.ts files to a separate folder
    "sourceMap": true,
    "types": ["node"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true
  },
  "exclude": ["node_modules", "src/test.ts"]
}
